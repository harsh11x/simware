<UserControl x:Class="Simware.Views.AnalysisWorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer>
        <StackPanel Margin="32">
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <TextBlock Text="Analysis Workspace" Style="{StaticResource DisplayFont}"/>
                <Button Content="Terminate Sandbox" Style="{StaticResource SimwareSecondaryButton}" HorizontalAlignment="Right"/>
            </Grid>
            
            <!-- Sandbox Status Bar -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,24">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖥️" Margin="0,0,12,0"/>
                        <TextBlock Text="Active Sandbox: vm-windows-10-testbed" Style="{StaticResource BodyMdFont}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="#1A238636" CornerRadius="8" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="ISOLATED" Foreground="{StaticResource SuccessBrush}" Style="{StaticResource LabelMdFont}"/>
                        </Border>
                        <Border Background="#1A9CA3AF" CornerRadius="8" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="CPU: 45%" Foreground="{StaticResource TextSecondaryBrush}" Style="{StaticResource LabelMdFont}"/>
                        </Border>
                        <Border Background="#1A9CA3AF" CornerRadius="8" Padding="8,4">
                            <TextBlock Text="RAM: 2.4GB" Foreground="{StaticResource TextSecondaryBrush}" Style="{StaticResource LabelMdFont}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Telemetry Streams -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Left Column -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,24">
                        <Grid>
                            <Rectangle Fill="{StaticResource PrimaryBrush}" Width="4" HorizontalAlignment="Left" />
                            <StackPanel Padding="16,16,16,16" Margin="4,0,0,0">
                                <TextBlock Text="Process Tree" Style="{StaticResource H2Font}" Margin="0,0,0,16"/>
                                <TextBlock Text="explorer.exe (PID: 2341)&#10; ↳ installer.exe (PID: 4402)&#10;    ↳ powershell.exe (PID: 4410)" Style="{StaticResource CodeMdFont}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Rectangle Fill="{StaticResource WarningBrush}" Width="4" HorizontalAlignment="Left" />
                            <StackPanel Padding="16,16,16,16" Margin="4,0,0,0">
                                <TextBlock Text="Network Activity" Style="{StaticResource H2Font}" Margin="0,0,0,16"/>
                                <TextBlock Text="TCP 10.0.0.5:54323 -> 185.12.X.X:443 (Suspicious IP)" Style="{StaticResource CodeMdFont}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
                
                <!-- Right Column (Live Log) -->
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="LIVE TELEMETRY" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Border Background="Black" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16">
                        <TextBlock Text="[10:42:01] Process created: C:\Windows\System32\cmd.exe&#10;[10:42:02] Network connection attempt to 192.168.1.104:443&#10;[10:42:05] File write blocked: C:\Users\Public\malware.exe&#10;[10:42:08] Injection detected in lsass.exe" Style="{StaticResource CodeMdFont}" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
