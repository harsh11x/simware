<UserControl x:Class="Simware.Views.GlobalSearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <StackPanel Margin="32">
        <TextBlock Text="Global Search" Style="{StaticResource DisplayFont}" Margin="0,0,0,24"/>
        
        <!-- Search Input -->
        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBox Text="Search by SHA-256 hash, filename, or IP address..." 
                         Foreground="{StaticResource TextPrimaryBrush}" Background="Transparent" BorderThickness="0" Width="800" VerticalAlignment="Center" 
                         FontFamily="Inter, sans-serif" FontSize="16"/>
            </StackPanel>
        </Border>
        
        <!-- Results Placeholder -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,100,0,0">
            <TextBlock Text="🔍" FontSize="48" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="Enter a search term to find previous analyses." Style="{StaticResource BodyMdFont}" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
