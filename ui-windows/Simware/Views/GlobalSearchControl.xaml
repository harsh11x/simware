<UserControl x:Class="Simware.Views.GlobalSearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <StackPanel Margin="32">
        <TextBlock Text="Global Search" Style="{StaticResource DisplayFont}" Margin="0,0,0,24"/>
        
        <!-- Search Input -->
        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtSearch" TextChanged="TxtSearch_TextChanged" 
                         Foreground="{StaticResource TextPrimaryBrush}" Background="Transparent" BorderThickness="0" Width="800" VerticalAlignment="Center" 
                         FontFamily="Inter, sans-serif" FontSize="16"/>
            </StackPanel>
        </Border>
        
        <!-- Results Area -->
        <Grid>
            <StackPanel x:Name="PlaceholderPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,100,0,0">
                <TextBlock Text="🔍" FontSize="48" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Enter a search term to find previous analyses." Style="{StaticResource BodyMdFont}" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
            
            <ItemsControl x:Name="SearchResultsList" Visibility="Collapsed">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📄" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}" Style="{StaticResource BodyMdFont}"/>
                                        <TextBlock Text="{Binding FileHash}" Style="{StaticResource CodeMdFont}"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="#1A238636" CornerRadius="8" Padding="8,4" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FinalDecision}" Foreground="{StaticResource SuccessBrush}" Style="{StaticResource LabelMdFont}"/>
                                    </Border>
                                    <Button Grid.Column="3" Content="Export Report" Tag="{Binding Id}" Click="Export_Click" Style="{StaticResource SimwareSecondaryButton}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="4" Content="View Details" Tag="{Binding Id}" Click="ViewDetails_Click" Style="{StaticResource SimwareSecondaryButton}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </StackPanel>
</UserControl>
