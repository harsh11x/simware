<Window x:Class="Simware.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simware" Height="700" Width="1100"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True"
        Foreground="{StaticResource TextPrimaryBrush}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <StackPanel Margin="0">
                <StackPanel Orientation="Horizontal" Margin="24,32,24,32">
                    <TextBlock Text="🛡️" FontSize="24" Margin="0,0,12,0"/>
                    <TextBlock Text="Simware" Style="{StaticResource H2Font}"/>
                </StackPanel>
                
                <StackPanel Margin="16,0,16,0">
                    <!-- Dashboard -->
                    <Button x:Name="NavDashboard" Click="Navigate_Click" Tag="Dashboard"
                            Background="{StaticResource SurfaceLighterBrush}" BorderThickness="0" Padding="12,10" Margin="0,0,0,8" HorizontalContentAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter Margin="{TemplateBinding Padding}" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" Style="{StaticResource BodyMdFont}"/>
                        </StackPanel>
                    </Button>

                    <!-- Workspace -->
                    <Button x:Name="NavWorkspace" Click="Navigate_Click" Tag="Workspace"
                            Background="Transparent" BorderThickness="0" Padding="12,10" Margin="0,0,0,8" HorizontalContentAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter Margin="{TemplateBinding Padding}" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,12,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Analysis Workspace" Style="{StaticResource BodyMdFont}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Search -->
                    <Button x:Name="NavSearch" Click="Navigate_Click" Tag="Search"
                            Background="Transparent" BorderThickness="0" Padding="12,10" Margin="0,0,0,8" HorizontalContentAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter Margin="{TemplateBinding Padding}" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,12,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Global Search" Style="{StaticResource BodyMdFont}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status -->
                <StackPanel Orientation="Horizontal" Margin="24,200,24,0">
                    <Ellipse Fill="{StaticResource SuccessBrush}" Width="8" Height="8" Margin="0,0,12,0"/>
                    <TextBlock Text="Agent Active • v1.0.4" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ContentControl x:Name="MainContent" Grid.Column="1" />
    </Grid>
</Window>
