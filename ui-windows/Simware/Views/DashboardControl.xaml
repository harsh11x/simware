<UserControl x:Class="Simware.Views.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer>
        <StackPanel Margin="32">
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <TextBlock Text="Overview" Style="{StaticResource DisplayFont}"/>
                <Button Content="Export Report" Style="{StaticResource SimwareButton}" HorizontalAlignment="Right"/>
            </Grid>
            
            <!-- Metrics -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Width="220" Margin="0,0,24,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FILES ANALYZED" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="1,248" Style="{StaticResource DisplayFont}"/>
                        <TextBlock Text="↑ 12% vs last week" Style="{StaticResource BodySmFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Width="220" Margin="0,0,24,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="THREATS BLOCKED" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="14" Style="{StaticResource DisplayFont}"/>
                        <TextBlock Text="↑ 3 new threats" Style="{StaticResource BodySmFont}" Foreground="{StaticResource DangerBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Width="220" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="AVG ANALYSIS TIME" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="1.2s" Style="{StaticResource DisplayFont}"/>
                        <TextBlock Text="Optimal" Style="{StaticResource BodySmFont}" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Recent Activity -->
            <TextBlock Text="Recent Simulations" Style="{StaticResource H2Font}" Margin="0,0,0,16"/>
            
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <Grid Padding="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📄" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="installer_v2.exe" Style="{StaticResource BodyMdFont}"/>
                            <TextBlock Text="a2b4...9f01" Style="{StaticResource CodeMdFont}"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#1A238636" CornerRadius="8" Padding="8,4" Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="CLEAN" Foreground="{StaticResource SuccessBrush}" Style="{StaticResource LabelMdFont}"/>
                        </Border>
                        <Button Grid.Column="3" Content="View Details" Style="{StaticResource SimwareSecondaryButton}" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" />
                    
                    <Grid Padding="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📄" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="invoice_update.pdf.exe" Style="{StaticResource BodyMdFont}"/>
                            <TextBlock Text="f7c9...33d2" Style="{StaticResource CodeMdFont}"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#1AF85149" CornerRadius="8" Padding="8,4" Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="MALICIOUS" Foreground="{StaticResource DangerBrush}" Style="{StaticResource LabelMdFont}"/>
                        </Border>
                        <Button Grid.Column="3" Content="View Details" Style="{StaticResource SimwareSecondaryButton}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
