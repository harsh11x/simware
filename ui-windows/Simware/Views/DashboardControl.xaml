<UserControl x:Class="Simware.Views.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer>
        <StackPanel Margin="32">
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <TextBlock Text="Overview" Style="{StaticResource DisplayFont}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Manual Scan" Click="ManualScan_Click" Style="{StaticResource SimwareButton}" Margin="0,0,12,0"/>
                </StackPanel>
            </Grid>
            
            <!-- Metrics -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Width="220" Margin="0,0,24,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FILES ANALYZED" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtFilesAnalyzed" Text="..." Style="{StaticResource DisplayFont}"/>
                        <TextBlock Text="All time" Style="{StaticResource BodySmFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Width="220" Margin="0,0,24,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="THREATS BLOCKED" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtThreatsBlocked" Text="..." Style="{StaticResource DisplayFont}"/>
                        <TextBlock x:Name="TxtThreatsTrend" Text="All time" Style="{StaticResource BodySmFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Width="220" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="AVG ANALYSIS TIME" Style="{StaticResource LabelMdFont}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtAvgTime" Text="..." Style="{StaticResource DisplayFont}"/>
                        <TextBlock Text="Optimal" Style="{StaticResource BodySmFont}" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Recent Activity -->
            <TextBlock Text="Recent Simulations" Style="{StaticResource H2Font}" Margin="0,0,0,16"/>
            
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <ItemsControl x:Name="RecentActivityList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📄" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}" Style="{StaticResource BodyMdFont}"/>
                                        <TextBlock Text="{Binding FileHash}" Style="{StaticResource CodeMdFont}"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="#1A238636" CornerRadius="8" Padding="8,4" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FinalDecision}" Foreground="{StaticResource SuccessBrush}" Style="{StaticResource LabelMdFont}"/>
                                    </Border>
                                    <Button Grid.Column="3" Content="Export Report" Tag="{Binding Id}" Click="Export_Click" Style="{StaticResource SimwareSecondaryButton}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="4" Content="View Details" Tag="{Binding Id}" Click="ViewDetails_Click" Style="{StaticResource SimwareSecondaryButton}" VerticalAlignment="Center"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
